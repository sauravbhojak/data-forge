# DataForge Backend — Environment Variables
# Copy this file to .env and adjust values as needed.

# Application
APP_NAME=DataForge
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Generation Limits
MAX_ROWS=1000000
PREVIEW_ROWS=50
MAX_FIELDS=100
MAX_TABLES=20
CHUNK_SIZE=1000

# Rate Limiting (format: "N/period" where period = second|minute|hour)
RATE_LIMIT_GENERATE=30/minute
RATE_LIMIT_EXPORT=10/minute
RATE_LIMIT_PREVIEW=60/minute

# Logging
LOG_LEVEL=INFO
LOG_JSON=true
